@model Alumni_Portal.ViewModels.AnnouncementViewModel

@{
    ViewData["Title"] = "Duyuru Düzenle";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 style="font-weight:600;color:#1a1a2e;margin-bottom:24px;">
                    <i class="bi bi-pencil-square me-2" style="color:#6c63ff;"></i>Duyuru Düzenle
                </h6>

                <form asp-action="Edit" asp-route-id="@Model.AnnouncementId" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-semibold" style="font-size:0.88rem;color:#555;">Başlık</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label fw-semibold" style="font-size:0.88rem;color:#555;">İçerik</label>
                        <textarea asp-for="Content" class="form-control" rows="6"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <div class="mb-3" style="font-size:0.85rem;color:#888;">
                        Oluşturulma: @Model.CreateDate?.ToString("dd.MM.yyyy HH:mm")
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label" style="font-size:0.88rem;">Aktif</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn text-white fw-semibold"
                                style="background:#6c63ff;border-radius:8px;padding:10px 24px;">
                            <i class="bi bi-check-lg me-1"></i> Güncelle
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary"
                           style="border-radius:8px;padding:10px 24px;">
                            İptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>