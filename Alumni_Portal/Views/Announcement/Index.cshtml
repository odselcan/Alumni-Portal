@using Alumni_Portal.Models
@model List<Announcement>

@{
    ViewData["Title"] = "Duyuru Yönetimi";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="d-flex align-items-center justify-content-between p-4">
            <h6 style="font-weight:600;color:#1a1a2e;margin:0;">
                <i class="bi bi-megaphone-fill me-2" style="color:#6c63ff;"></i>
                Duyurular
                <span class="badge ms-2" style="background:#ede9ff;color:#6c63ff;font-size:0.78rem;">
                    @Model.Count adet
                </span>
            </h6>
            <a asp-action="Create" class="btn text-white fw-semibold"
               style="background:#6c63ff;border-radius:8px;padding:8px 20px;font-size:0.9rem;">
                <i class="bi bi-plus-lg me-1"></i> Yeni Duyuru
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#f8f8ff;">
                    <tr>
                        <th class="px-4 py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">BAŞLIK</th>
                        <th class="py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">İÇERİK</th>
                        <th class="py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">TARİH</th>
                        <th class="py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">DURUM</th>
                        <th class="py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">İŞLEM</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5" style="color:#aaa;">
                                <i class="bi bi-inbox" style="font-size:2.5rem;"></i>
                                <p class="mt-2 mb-0">Henüz duyuru bulunmuyor.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var a in Model)
                        {
                            <tr>
                                <td class="px-4 py-3">
                                    <div style="font-weight:500;color:#1a1a2e;font-size:0.92rem;">@a.Title</div>
                                </td>
                                <td class="py-3">
                                    <div style="font-size:0.85rem;color:#666;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                        @a.Content
                                    </div>
                                </td>
                                <td class="py-3">
                                    <span style="font-size:0.85rem;color:#888;">
                                        @(a.CreateDate?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                                    </span>
                                </td>
                                <td class="py-3">
                                    @if (a.IsActive)
                                    {
                                        <span class="badge" style="background:#e6f9f0;color:#16a34a;font-size:0.78rem;padding:6px 10px;border-radius:6px;">
                                            <i class="bi bi-check-circle me-1"></i>Aktif
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background:#f5f5f5;color:#aaa;font-size:0.78rem;padding:6px 10px;border-radius:6px;">
                                            Pasif
                                        </span>
                                    }
                                </td>
                                <td class="py-3">
                                    <div class="d-flex gap-2">
                                        <a asp-action="Edit" asp-route-id="@a.AnnouncementId"
                                           class="btn btn-sm btn-outline-primary" style="border-radius:6px;">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@a.AnnouncementId" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                                    style="border-radius:6px;"
                                                    onclick="return confirm('Bu duyuruyu silmek istediğinize emin misiniz?')">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>