@model Alumni_Portal.Models.Announcement

@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <a asp-controller="Home" asp-action="Index" 
               class="btn btn-sm mb-4"
               style="background:#f0efff;color:#6c63ff;border-radius:8px;border:none;">
                <i class="bi bi-arrow-left me-1"></i> Geri Dön
            </a>

            <div class="card border-0 shadow-sm">
                <div class="card-body p-4" style="border-left:4px solid #6c63ff;border-radius:12px;">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h4 style="font-weight:700;color:#1a1a2e;">@Model.Title</h4>
                        <span style="font-size:0.8rem;color:#aaa;white-space:nowrap;margin-left:12px;">
                            @(Model.CreateDate?.ToString("dd.MM.yyyy") ?? "")
                        </span>
                    </div>
                    <hr style="border-color:#f0efff;" />
                    <div style="font-size:0.95rem;color:#444;line-height:1.8;white-space:pre-wrap;">
                        @Model.Content
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>