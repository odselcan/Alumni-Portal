@using Alumni_Portal.Models
@model List<Graduate>

@{
    ViewData["Title"] = "Mezun Listesi";
}

<!-- Filtre Kartı -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <form method="get" asp-action="Index" asp-controller="Admin">
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold" style="color:#555;">Arama</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search" style="color:#6c63ff;"></i>
                        </span>
                        <input type="text" name="search" value="@ViewBag.Search"
                               class="form-control border-start-0"
                               placeholder="Ad, soyad veya e-posta..." />
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold" style="color:#555;">Fakülte</label>
                    <select name="faculty" class="form-select">
                        <option value="">Tüm Fakülteler</option>
                        @foreach (var f in (List<string>)ViewBag.Faculties)
                        {
                            <option value="@f" selected="@(ViewBag.SelectedFaculty == f)">@f</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold" style="color:#555;">Çalışma Durumu</label>
                    <select name="employmentStatus" class="form-select">
                        <option value="">Tümü</option>
                        <option value="employed" selected="@(ViewBag.SelectedStatus == "employed")">Çalışıyor</option>
                        <option value="job_seeking" selected="@(ViewBag.SelectedStatus == "job_seeking")">İş Arıyor</option>
                        <option value="academic" selected="@(ViewBag.SelectedStatus == "academic")">Akademik</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn w-100 text-white fw-semibold"
                            style="background:#6c63ff;border-radius:8px;padding:10px;">
                        <i class="bi bi-funnel me-1"></i> Filtrele
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Bildirim -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Mezun Listesi -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="d-flex align-items-center justify-content-between p-4 pb-0">
            <h6 style="font-weight:600;color:#1a1a2e;margin:0;">
                <i class="bi bi-people-fill me-2" style="color:#6c63ff;"></i>
                Mezunlar
                <span class="badge ms-2" style="background:#ede9ff;color:#6c63ff;font-size:0.78rem;">
                    @Model.Count kişi
                </span>
            </h6>
            <div class="d-flex gap-2">
                <a asp-controller="Admin" asp-action="ExportExcel" class="btn btn-sm btn-outline-success">
                    <i class="bi bi-file-earmark-excel me-1"></i> Excel
                </a>
                <a asp-controller="Admin" asp-action="ExportPdf" class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-file-earmark-pdf me-1"></i> PDF
                </a>
            </div>
        </div>

        <div class="table-responsive mt-3">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#f8f8ff;">
                    <tr>
                        <th class="px-4 py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">MEZUN</th>
                        <th class="py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">FAKÜLTE / BÖLÜM</th>
                        <th class="py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">MEZUNİYET</th>
                        <th class="py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">DURUM</th>
                        <th class="py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">ŞİRKET</th>
                        <th class="py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">İLETİŞİM</th>
                        <th class="py-3" style="font-size:0.82rem;color:#888;font-weight:600;border:none;">İŞLEM</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5" style="color:#aaa;">
                                <i class="bi bi-inbox" style="font-size:2.5rem;"></i>
                                <p class="mt-2 mb-0">Kayıt bulunamadı.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var g in Model)
                        {
                            var initials = $"{g.FirstName?.Substring(0, 1)}{g.LastName?.Substring(0, 1)}".ToUpper();
                            var status = g.GraduateCareer?.EmploymentStatus;
                            <tr>
                                <td class="px-4 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div style="width:40px;height:40px;border-radius:50%;background:#ede9ff;display:flex;align-items:center;justify-content:center;font-size:0.85rem;font-weight:600;color:#6c63ff;flex-shrink:0;">
                                            @initials
                                        </div>
                                        <div>
                                            <div style="font-weight:500;color:#1a1a2e;font-size:0.92rem;">@g.FirstName @g.LastName</div>
                                            <div style="font-size:0.78rem;color:#888;">@g.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <div style="font-size:0.88rem;color:#1a1a2e;">@(g.Faculty ?? "-")</div>
                                    <div style="font-size:0.78rem;color:#888;">@(g.Department ?? "-")</div>
                                </td>
                                <td class="py-3">
                                    <span style="font-size:0.88rem;color:#555;">
                                        @(g.GraduationDate.HasValue ? g.GraduationDate.Value.ToString("MM/yyyy") : "-")
                                    </span>
                                </td>
                                <td class="py-3">
                                    @if (status == "employed")
                                    {
                                        <span class="badge" style="background:#e6f9f0;color:#16a34a;font-size:0.78rem;padding:6px 10px;border-radius:6px;">
                                            <i class="bi bi-briefcase-fill me-1"></i>Çalışıyor
                                        </span>
                                    }
                                    else if (status == "job_seeking")
                                    {
                                        <span class="badge" style="background:#fff7e6;color:#d97706;font-size:0.78rem;padding:6px 10px;border-radius:6px;">
                                            <i class="bi bi-search me-1"></i>İş Arıyor
                                        </span>
                                    }
                                    else if (status == "academic")
                                    {
                                        <span class="badge" style="background:#e6f0ff;color:#2563eb;font-size:0.78rem;padding:6px 10px;border-radius:6px;">
                                            <i class="bi bi-book-fill me-1"></i>Akademik
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge" style="background:#f5f5f5;color:#aaa;font-size:0.78rem;padding:6px 10px;border-radius:6px;">
                                            Belirtilmemiş
                                        </span>
                                    }
                                </td>
                                <td class="py-3">
                                    <div style="font-size:0.88rem;color:#1a1a2e;">@(g.GraduateCareer?.CompanyName ?? "-")</div>
                                    <div style="font-size:0.78rem;color:#888;">@(g.GraduateCareer?.Position ?? "-")</div>
                                </td>
                                <td class="py-3">
                                    <div style="font-size:0.82rem;color:#555;">@(g.Phone ?? "-")</div>
                                </td>
                                <td class="py-3">
                                    <form method="post"
                                          asp-action="Delete"
                                          asp-controller="Admin"
                                          asp-route-id="@g.GraduateId"
                                          onsubmit="return confirm('@g.FirstName @g.LastName adlı mezunu silmek istediğinize emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>