@model Alumni_Portal.ViewModels.AdminCreateViewModel

@{
    ViewData["Title"] = "Admin Ekle";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 style="font-weight:600;color:#1a1a2e;margin-bottom:24px;">
                    <i class="bi bi-shield-plus me-2" style="color:#6c63ff;"></i>Yeni Admin Ekle
                </h6>

                <form asp-action="CreateAdmin" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label asp-for="FirstName" class="form-label fw-semibold" style="font-size:0.88rem;color:#555;">Ad</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Adınız" />
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="LastName" class="form-label fw-semibold" style="font-size:0.88rem;color:#555;">Soyad</label>
                            <input asp-for="LastName" class="form-control" placeholder="Soyadınız" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Email" class="form-label fw-semibold" style="font-size:0.88rem;color:#555;">E-posta</label>
                            <input asp-for="Email" class="form-control" placeholder="admin@universite.edu.tr" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Password" class="form-label fw-semibold" style="font-size:0.88rem;color:#555;">Şifre</label>
                            <input asp-for="Password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold" style="font-size:0.88rem;color:#555;">Şifre Tekrar</label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn text-white fw-semibold"
                                style="background:#6c63ff;border-radius:8px;padding:10px 24px;">
                            <i class="bi bi-shield-check me-1"></i> Admin Ekle
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary"
                           style="border-radius:8px;padding:10px 24px;">
                            İptal
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>