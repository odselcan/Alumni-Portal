@model Alumni_Portal.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alumni Portal - Giriş</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: #eef0f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
        }

        .login-wrapper {
            display: flex;
            width: 860px;
            min-height: 520px;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0,0,0,0.12);
            background: white;
        }

        /* Sol form alanı */
        .login-form-side {
            flex: 1;
            padding: 52px 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .login-form-side .brand {
            color: #6c63ff;
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 24px;
            letter-spacing: 0.3px;
        }

        .login-form-side h2 {
            font-size: 1.9rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 6px;
        }

        .login-form-side .subtitle {
            color: #888;
            font-size: 0.92rem;
            margin-bottom: 32px;
        }

        .form-label {
            font-size: 0.85rem;
            color: #555;
            margin-bottom: 6px;
        }

        .form-control {
            border: 1.5px solid #e0e0e0;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 0.95rem;
            transition: border-color 0.2s;
        }

        .form-control:focus {
            border-color: #6c63ff;
            box-shadow: 0 0 0 3px rgba(108,99,255,0.1);
        }

        .btn-login {
            background: #6c63ff;
            color: white;
            border: none;
            border-radius: 10px;
            padding: 13px;
            font-size: 1rem;
            font-weight: 600;
            width: 100%;
            margin-top: 8px;
            transition: background 0.2s;
        }

        .btn-login:hover {
            background: #574fd6;
        }

        /* Sağ panel */
        .login-banner-side {
            width: 340px;
            background: linear-gradient(135deg, #7c73f5 0%, #6c63ff 50%, #a78bfa 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px 36px;
            border-radius: 0 16px 16px 0;
        }

        .login-banner-side h3 {
            color: white;
            font-size: 1.7rem;
            font-weight: 700;
            line-height: 1.4;
        }

        .text-danger { font-size: 0.82rem; }

        .alert-danger {
            border-radius: 8px;
            font-size: 0.88rem;
            padding: 10px 14px;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <!-- Sol: Form -->
        <div class="login-form-side">
            <div class="brand">Mezun Yönetim Sistemi</div>
            <h2>Hoş Geldiniz</h2>
            <p class="subtitle">Lütfen bilgilerinizi giriniz.</p>

            <form asp-action="Index" asp-controller="Login" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label">E-posta Adresi</label>
                    <input asp-for="Email" class="form-control" placeholder="ornek@universite.edu.tr" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label">Şifre</label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-login">Giriş Yap</button>

                <div class="text-center mt-3">
                    <a asp-controller="Register" asp-action="Index"
                       class="text-decoration-none small" style="color:#6c63ff;">
                        Hesabınız yok mu? Kayıt olun
                    </a>
                </div>
            </form>
        </div>

        <!-- Sağ: Banner -->
        <div class="login-banner-side">
            <h3>Geleceği Mezunlarımızla İnşa Ediyoruz</h3>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>