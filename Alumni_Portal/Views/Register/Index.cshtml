@model Alumni_Portal.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Kayıt Ol";
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Alumni Portal - Kayıt Ol</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: #eef0f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
        }

        .register-wrapper {
            display: flex;
            width: 860px;
            min-height: 580px;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0,0,0,0.12);
            background: white;
        }

        .register-form-side {
            flex: 1;
            padding: 48px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .register-form-side .brand {
            color: #6c63ff;
            font-size: 0.95rem;
            font-weight: 600;
            margin-bottom: 20px;
        }

        .register-form-side h2 {
            font-size: 1.8rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: 6px;
        }

        .register-form-side .subtitle {
            color: #888;
            font-size: 0.92rem;
            margin-bottom: 28px;
        }

        .form-label {
            font-size: 0.85rem;
            color: #555;
            margin-bottom: 6px;
        }

        .form-control {
            border: 1.5px solid #e0e0e0;
            border-radius: 10px;
            padding: 11px 16px;
            font-size: 0.95rem;
            transition: border-color 0.2s;
        }

        .form-control:focus {
            border-color: #6c63ff;
            box-shadow: 0 0 0 3px rgba(108,99,255,0.1);
        }

        .btn-register {
            background: #6c63ff;
            color: white;
            border: none;
            border-radius: 10px;
            padding: 13px;
            font-size: 1rem;
            font-weight: 600;
            width: 100%;
            margin-top: 8px;
            transition: background 0.2s;
        }

        .btn-register:hover { background: #574fd6; }

        .register-banner-side {
            width: 300px;
            background: linear-gradient(135deg, #7c73f5 0%, #6c63ff 50%, #a78bfa 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 48px 32px;
            border-radius: 0 16px 16px 0;
        }

        .register-banner-side h3 {
            color: white;
            font-size: 1.6rem;
            font-weight: 700;
            line-height: 1.4;
        }

        .text-danger { font-size: 0.82rem; }
    </style>
</head>
<body>
    <div class="register-wrapper">
        <!-- Sol: Form -->
        <div class="register-form-side">
            <div class="brand">Mezun Yönetim Sistemi</div>
            <h2>Kayıt Ol</h2>
            <p class="subtitle">Bilgilerinizi doldurarak hesap oluşturun.</p>

            <form asp-action="Index" asp-controller="Register" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-6">
                        <label asp-for="FirstName" class="form-label">Ad</label>
                        <input asp-for="FirstName" class="form-control" placeholder="Adınız" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="LastName" class="form-label">Soyad</label>
                        <input asp-for="LastName" class="form-control" placeholder="Soyadınız" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Email" class="form-label">E-posta</label>
                        <input asp-for="Email" class="form-control" placeholder="ornek@universite.edu.tr" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="Password" class="form-label">Şifre</label>
                        <input asp-for="Password" class="form-control" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="ConfirmPassword" class="form-label">Şifre Tekrar</label>
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="Faculty" class="form-label">Fakülte</label>
                        <input asp-for="Faculty" class="form-control" placeholder="Fakülteniz" />
                    </div>
                    <div class="col-6">
                        <label asp-for="Department" class="form-label">Bölüm</label>
                        <input asp-for="Department" class="form-control" placeholder="Bölümünüz" />
                    </div>
                    <div class="col-12">
                        <label asp-for="GraduationDate" class="form-label">Mezuniyet Tarihi</label>
                        <input asp-for="GraduationDate" class="form-control" type="date" />
                    </div>
                    <div class="col-12">
    <label asp-for="BirthDate" class="form-label">Doğum Tarihi</label>
    <input asp-for="BirthDate" class="form-control" type="date" />
</div>
                </div>

                <button type="submit" class="btn-register mt-3">Kayıt Ol</button>

                <div class="text-center mt-3">
                    <a asp-controller="Login" asp-action="Index"
                       class="text-decoration-none small" style="color:#6c63ff;">
                        Zaten hesabınız var mı? Giriş yapın
                    </a>
                </div>
            </form>
        </div>

        <!-- Sağ: Banner -->
        <div class="register-banner-side">
            <h3>Mezun Ağına Katılın</h3>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>